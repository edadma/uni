#!/bin/bash
set -e

# Build first
echo "Building for Raspberry Pi Pico W..."
cargo build --no-default-features --features target-pico --target thumbv6m-none-eabi --release

echo ""
# Show binary size information
echo "Binary size:"
size target/thumbv6m-none-eabi/release/uni
echo ""
echo "Flash usage (text + data):"
arm-none-eabi-size target/thumbv6m-none-eabi/release/uni | tail -n 1 | awk '{printf "  %d bytes (%.1f%% of 2MB)\n", $1+$2, ($1+$2)/2097152*100}'
echo ""

echo "Converting ELF to UF2..."
elf2uf2-rs target/thumbv6m-none-eabi/release/uni target/thumbv6m-none-eabi/release/uni.uf2

echo "Looking for mounted Pico..."
if [ -d "/media/$USER/RPI-RP2" ]; then
    echo "Found Pico at /media/$USER/RPI-RP2"
    echo "Copying UF2 file..."
    cp target/thumbv6m-none-eabi/release/uni.uf2 /media/$USER/RPI-RP2/
    echo "Syncing filesystem..."
    sync
    echo "Done! The Pico should automatically reboot and unmount."
    echo "Wait a few seconds, then connect with: picocom /dev/ttyACM0 -b 115200"
else
    echo "Pico not found. Please:"
    echo "1. Hold BOOTSEL button on Pico"
    echo "2. Plug in USB cable"
    echo "3. Release BOOTSEL button"
    echo "4. Run this script again"
fi
