#!/bin/bash
set -e

echo "Building Uni for Raspberry Pi Pico 2..."
cargo build --no-default-features --features target-pico2 --target thumbv8m.main-none-eabihf --release

echo ""
echo "Build complete!"
echo "Binary location: target/thumbv8m.main-none-eabihf/release/uni"
echo ""

# Show binary size information
echo "Binary size:"
size target/thumbv8m.main-none-eabihf/release/uni
echo ""
echo "Flash usage (text + data):"
arm-none-eabi-size target/thumbv8m.main-none-eabihf/release/uni | tail -n 1 | awk '{printf "  %d bytes (%.1f%% of 4MB)\n", $1+$2, ($1+$2)/4194304*100}'
echo ""

echo "Converting to UF2 format (requires picotool)..."
picotool uf2 convert target/thumbv8m.main-none-eabihf/release/uni -t elf \
    target/thumbv8m.main-none-eabihf/release/uni.uf2 \
    --family rp2350-arm-s
echo ""

echo "Next steps:"
echo "  ./flash_pico2   # Flash to connected Pico 2"
echo ""
echo "Or manually copy:"
echo "  cp target/thumbv8m.main-none-eabihf/release/uni.uf2 /media/\$USER/RP2350/"
echo ""
