#!/bin/bash
set -e

# Build first
echo "Building for micro:bit..."
cargo build --no-default-features --features target-microbit --target thumbv7em-none-eabihf --release

echo ""
# Show binary size information
echo "Binary size:"
size target/thumbv7em-none-eabihf/release/uni
echo ""
echo "Flash usage (text + data):"
arm-none-eabi-size target/thumbv7em-none-eabihf/release/uni | tail -n 1 | awk '{printf "  %d bytes (%.1f%% of 512KB)\n", $1+$2, ($1+$2)/524288*100}'
echo ""

echo "Looking for mounted micro:bit..."
if [ -d "/media/$USER/MICROBIT" ]; then
    echo "Found micro:bit at /media/$USER/MICROBIT"
    echo "Copying .hex file..."
    arm-none-eabi-objcopy -O ihex target/thumbv7em-none-eabihf/release/uni /media/$USER/MICROBIT/uni.hex
    echo "Syncing filesystem..."
    sync
    echo "Done! The micro:bit should automatically reboot."
    echo "Connect with: picocom /dev/ttyACM0 -b 115200"
else
    echo "micro:bit not found. Please:"
    echo "1. Connect micro:bit via USB"
    echo "2. Wait for it to mount"
    echo "3. Run this script again"
fi
