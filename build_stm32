#!/bin/bash
set -e

echo "Building Uni for STM32H753ZI..."
cargo build --no-default-features --features target-stm32h753zi --target thumbv7em-none-eabihf --release

echo ""
echo "Build complete!"
echo "Binary location: target/thumbv7em-none-eabihf/release/uni"
echo ""

# Show binary size information
echo "Binary size:"
size target/thumbv7em-none-eabihf/release/uni
echo ""
echo "Flash usage (text + data):"
arm-none-eabi-size target/thumbv7em-none-eabihf/release/uni | tail -n 1 | awk '{printf "  %d bytes (%.1f%% of 2MB)\n", $1+$2, ($1+$2)/2097152*100}'
echo ""

echo "Next steps:"
echo "  ./flash_stm32   # Flash to connected STM32H753ZI"
echo ""
