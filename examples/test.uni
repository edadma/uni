#!/usr/bin/env target/debug/uni
\ This is a test Uni program
\ It demonstrates basic arithmetic and printing

5 3 + pr    \ Print 8
10 4 - pr   \ Print 6
7 3 mod pr  \ Print 1 (modulo)
5 5 = pr    \ Print 1 (true)
3 7 = pr    \ Print 0 (false)

\ Test some stack operations
1 2 3 swap pr drop pr  \ Should print 2, then 1

'factorial [
  dup 1 = [
    drop 1                  \ Base case: factorial(0) = factorial(1) = 1
  ] [
    dup 1 - factorial *    \ Recursive case: n * factorial(n-1)
  ] if
] def

5 factorial pr             \ Prints 120

\ times loop: execute block n times
'times [
  >r                   \ move block to return stack
  dup 0 >              \ check if counter > 0
  [
    r@ exec 1 - r>     \ execute block, decrement counter, restore block
    times              \ recursive call
  ]
  [ drop r> drop ]     \ cleanup: drop counter and block
  if
] def

5 [ "hello" pr ] times

\ Count from 1 to 5
1                      \ initial counter
[ dup 5 <= ]           \ condition: counter <= 5
[ dup pr 1 + ]         \ body: print counter and increment
while
drop                   \ clean up final counter

\ Sum all numbers in a list
'sum-helper [
  \ Stack: [acc list]
  dup nil? [
    \ List is empty: [acc []]
    drop            \ Drop the empty list, leave acc: [acc]
  ] [
    \ List not empty: [acc [head|tail]]
    dup head        \ [acc list head]
    rot +           \ [list (acc+head)]  - add head to acc
    swap            \ [(acc+head) list]
    dup tail        \ [(acc+head) list tail]
    nip             \ [(acc+head) tail] - remove original list
    sum-helper      \ recurse with new acc and tail
  ] if
] def

'sum [
  0 swap sum-helper
] def

[1 2 3 4 5] sum pr         \ Should print 15
