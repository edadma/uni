#!/usr/bin/env uni
\ This is a test Uni program
\ It demonstrates basic arithmetic and printing

5 3 + pr    \ Print 8
10 4 - pr   \ Print 6
7 3 mod pr  \ Print 1 (modulo)
5 5 = pr    \ Print 1 (true)
3 7 = pr    \ Print 0 (false)

\ Test some stack operations
1 2 3 swap pr drop pr  \ Should print 2, then 1